<script>
/* ─── CONFIG ────────────────────────────────────── */
const JSON_URL = 'https://raw.githubusercontent.com/abdellahcharafeddine622-tech/abdelh/refs/heads/main/abdelk.json';

/* ─── HELPERS ───────────────────────────────────── */
const typeConfig = {
  news:    { badge: 'خبر',    cls: 'badge-news',    emoji: '📰', bg: 'linear-gradient(135deg,#0d2b26,#1a4a40)' },
  podcast: { badge: 'بودكاست', cls: 'badge-podcast', emoji: '🎙️', bg: 'linear-gradient(135deg,#2b1d0a,#4a3010)' },
  video:   { badge: 'فيديو',  cls: 'badge-video',   emoji: '🎬', bg: 'linear-gradient(135deg,#1a0d0d,#2e1515)' },
  photo:   { badge: 'صور',   cls: 'badge-photo',   emoji: '📷', bg: 'linear-gradient(135deg,#1a0d2b,#2e154a)' },
};

function thumbHTML(item, big = false) {
  const cfg = typeConfig[item.type] || typeConfig.news;
  const size = big ? 48 : 28;
  const pic = item.picture;
  return `
    <div class="card-thumb-placeholder">
      <div class="thumb-gradient" style="background:${cfg.bg};"></div>
      ${pic ? `<img class="thumb-img" src="${pic}" alt="" onerror="this.style.display='none'"/>` : ''}
      <div class="thumb-icon" style="font-size:${size}px;">${cfg.emoji}</div>
    </div>`;
}

function buildAllPosts(data) {
  const items = [];
  (data.news    || []).forEach(i => items.push({...i, type:'news'}));
  (data.podcasts|| []).forEach(i => items.push({...i, type:'podcast'}));
  (data.videos  || []).forEach(i => items.push({...i, type:'video'}));
  (data.photos  || []).forEach(i => items.push({...i, type:'photo'}));
  return items;
}

/* ─── CURSOR ────────────────────────────────────── */
const cursor = document.getElementById('cursor');
const ring   = document.getElementById('cursorRing');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cursor.style.left=mx+'px';cursor.style.top=my+'px';});
(function animRing(){rx+=(mx-rx)*0.12;ry+=(my-ry)*0.12;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(animRing);})();

/* ─── NAVBAR ────────────────────────────────────── */
window.addEventListener('scroll',()=>document.getElementById('navbar').classList.toggle('scrolled',scrollY>60));

/* ─── COUNTER ───────────────────────────────────── */
function animCount(el,target){
  if(!el||isNaN(target))return;
  let v=0;const step=target/(1800/16);
  const t=setInterval(()=>{v=Math.min(v+step,target);el.textContent=Math.floor(v);if(v>=target)clearInterval(t);},16);
}

/* ─── FADE IN OBSERVER ──────────────────────────── */
const obs = new IntersectionObserver(entries=>{
  entries.forEach((e,i)=>{if(e.isIntersecting){setTimeout(()=>e.target.classList.add('visible'),i*80);obs.unobserve(e.target);}});
},{threshold:0.1});
function observeFadeIns(){ document.querySelectorAll('.fade-in:not(.visible)').forEach(el=>obs.observe(el)); }

/* ─── RENDER FEATURED ───────────────────────────── */
function renderFeatured(data) {
  const grid = document.getElementById('featuredGrid');
  const allItems = buildAllPosts(data);

  // Main = first item with featured:true, or first overall
  const main = allItems.find(i=>i.featured) || allItems[0];
  // Side = next 2 different items
  const sides = allItems.filter(i=>i!==main).slice(0,2);

  if (!main) { grid.innerHTML = '<div class="error-state"><p>لا يوجد محتوى بعد.</p></div>'; return; }

  const cfg = typeConfig[main.type] || typeConfig.news;
  const read = main.readTime || main.duration || '';

  let mainHTML = `
    <a class="card-main fade-in" href="#" onclick="openModal('${main.id}'); return false;">
      <div class="card-thumb" style="aspect-ratio:16/8;">
        ${thumbHTML(main, true)}
        <span class="card-badge ${cfg.cls}">${cfg.badge}</span>
      </div>
      <div class="card-body">
        <div class="card-meta">
          <span>${main.date||''}</span>
          ${main.author?`<span class="card-meta-dot"></span><span>${main.author}</span>`:''}
          ${read?`<span class="card-meta-dot"></span><span>${read}</span>`:''}
        </div>
        <h3 class="card-title">${main.title}</h3>
        <p class="card-desc">${main.description||''}</p>
        <div class="card-footer"><span class="read-more">← اقرأ التقرير كاملاً</span></div>
      </div>
    </a>`;

  let sidesHTML = sides.map(item => {
    const c = typeConfig[item.type] || typeConfig.news;
    const r = item.readTime || item.duration || '';
    const ep = item.episode ? `الحلقة ${item.episode}` : '';
    return `
      <a class="card-side fade-in" href="#" onclick="openModal('${item.id}'); return false;">
        <div class="card-thumb" style="min-width:120px;width:120px;height:auto;">
          ${thumbHTML(item, false)}
          <span class="card-badge ${c.cls}" style="top:8px;right:8px;font-size:9px;padding:3px 7px;">${ep||c.badge}</span>
        </div>
        <div class="card-body">
          <div class="card-meta">${ep?`<span>${ep}</span><span class="card-meta-dot"></span>`:''}<span>${r||item.date||''}</span></div>
          <h3 class="card-title">${item.title}</h3>
          <p class="card-desc">${item.description||''}</p>
          <span class="read-more" style="font-size:10px;margin-top:8px;display:flex;">← عرض</span>
        </div>
      </a>`;
  }).join('');

  grid.innerHTML = mainHTML + (sides.length ? `<div class="cards-side">${sidesHTML}</div>` : '');
}

/* ─── RENDER POSTS GRID ─────────────────────────── */
let allPostsCache = [];
function renderPosts(filter) {
  const grid = document.getElementById('postsGrid');
  const items = filter==='all' ? allPostsCache : allPostsCache.filter(p=>p.type===filter);
  if (!items.length) {
    grid.innerHTML = '<div class="error-state" style="grid-column:1/-1;"><p>لا يوجد محتوى في هذا القسم.</p></div>';
    return;
  }
  grid.innerHTML = items.map(p => {
    const cfg = typeConfig[p.type] || typeConfig.news;
    const r = p.readTime || p.duration || '';
    return `
      <a class="post-card" href="#" onclick="openModal('${p.id}'); return false;">
        <div class="card-thumb">
          ${thumbHTML(p, false)}
          <span class="card-badge ${cfg.cls}" style="right:12px;left:auto;">${cfg.badge}</span>
        </div>
        <div class="card-body">
          <div class="card-meta"><span>${p.date||''}</span>${r?`<span class="card-meta-dot"></span><span>${r}</span>`:''}</div>
          <h3 class="card-title">${p.title}</h3>
          <p class="card-desc">${p.description||''}</p>
          <div class="card-footer"><span class="read-more">← عرض</span></div>
        </div>
      </a>`;
  }).join('');
}

function filterPosts(type, btn) {
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderPosts(type);
}

/* ─── RENDER PODCASTS ───────────────────────────── */
function renderPodcasts(podcasts) {
  const list = document.getElementById('podcastList');
  if (!podcasts || !podcasts.length) {
    list.innerHTML = '<div class="error-state"><p>لا توجد حلقات بعد.</p></div>'; return;
  }
  list.innerHTML = podcasts.map(ep => {
    const num = String(ep.episode||'').padStart(2,'0');
    const coming = !ep.audio && ep.coming_soon !== false && !ep.coming_soon;
    return `
      <a class="podcast-ep" href="#" onclick="openModal('${ep.id}'); return false;">
        <div class="ep-num">${num}</div>
        <div class="ep-play">▶</div>
        <div class="ep-info">
          <div class="ep-title">${ep.title}</div>
          <div class="ep-desc">${ep.description||''}</div>
        </div>
        <div class="ep-meta">
          <span>${ep.date||'قريباً'}</span>
          <span class="${ep.duration&&!coming?'ep-duration':'coming-soon-badge'}">${ep.duration||'— : —'}</span>
        </div>
      </a>`;
  }).join('');
}

/* ─── RENDER VIDEOS ─────────────────────────────── */
function renderVideos(videos) {
  const grid = document.getElementById('videosGrid');
  if (!videos || !videos.length) {
    grid.innerHTML = '<div class="error-state" style="grid-column:1/-1;"><p>لا توجد فيديوهات بعد.</p></div>'; return;
  }
  grid.innerHTML = videos.map(v => `
    <a class="video-card fade-in" href="#" onclick="openModal('${v.id}'); return false;">
      <div class="video-thumb">
        <div class="card-thumb">
          <div class="card-thumb-placeholder">
            <div class="thumb-gradient" style="background:linear-gradient(135deg,#1a0d0d,#2e1515,#0d0d1a);"></div>
            ${v.picture?`<img class="thumb-img" src="${v.picture}" alt="" onerror="this.style.display='none'"/>`:''}
            <div class="thumb-icon" style="font-size:40px;">🎬</div>
          </div>
        </div>
        <div class="play-btn"><div class="play-circle">▶</div></div>
        <span class="card-badge badge-video" style="top:12px;right:12px;">فيديو</span>
      </div>
      <div class="card-body">
        <div class="card-meta"><span>${v.date||'قريباً'}</span>${v.duration?`<span class="card-meta-dot"></span><span>${v.duration}</span>`:''}</div>
        <h3 class="card-title">${v.title}</h3>
        <p class="card-desc">${v.description||''}</p>
      </div>
    </a>`).join('');
}

/* ─── MODAL OPEN ────────────────────────────────── */
let allDataCache = {};

function openModal(id) {
  // Find item across all types
  const allItems = buildAllPosts(allDataCache);
  const item = allItems.find(i=>i.id===id);
  if (!item) return;

  const cfg = typeConfig[item.type] || typeConfig.news;
  document.getElementById('modalTitle').textContent = item.title;

  // Build media HTML
  let mediaHTML = '';
  if (item.type === 'video') {
    if (item.video) {
      const isYT = item.video.includes('youtube.com') || item.video.includes('youtu.be');
      if (isYT) {
        // Convert to embed URL
        let embedUrl = item.video.replace('watch?v=','embed/').replace('youtu.be/','www.youtube.com/embed/');
        mediaHTML = `<div class="modal-media" style="aspect-ratio:16/9;"><iframe src="${embedUrl}" allowfullscreen style="aspect-ratio:16/9;"></iframe></div>`;
      } else {
        mediaHTML = `<div class="modal-media"><video controls src="${item.video}"></video></div>`;
      }
    } else {
      mediaHTML = `<div class="media-placeholder"><div class="big-emoji">🎬</div><span>الفيديو قريباً</span></div>`;
    }
  } else if (item.type === 'podcast') {
    if (item.audio) {
      mediaHTML = `<div class="modal-media" style="padding:16px;background:var(--card2);border-radius:12px;margin-top:16px;"><audio controls src="${item.audio}" style="width:100%;"></audio></div>`;
    } else {
      mediaHTML = `<div class="media-placeholder"><div class="big-emoji">🎙️</div><span>الصوت قريباً</span></div>`;
    }
  } else if (item.type === 'photo') {
    const pics = item.pictures || (item.picture ? [item.picture] : []);
    if (pics.length) {
      mediaHTML = pics.map(src=>`<img class="modal-img" src="${src}" alt="" onerror="this.style.display='none'"/>`).join('');
    }
  }

  // Author / read time
  const meta1 = item.date || '';
  const meta2 = item.author ? `بقلم: ${item.author}` : '';
  const meta3 = item.readTime ? `${item.readTime} قراءة` : (item.duration||'');

  document.getElementById('modalBody').innerHTML = `
    <span class="modal-badge ${cfg.cls}">${cfg.badge}</span>
    <div class="meta">
      ${meta1?`<span>${meta1}</span>`:''}
      ${meta2?`<span>${meta2}</span>`:''}
      ${meta3?`<span>${meta3}</span>`:''}
    </div>
    ${item.content || `<p>${item.description||''}</p>`}
    ${mediaHTML}`;

  document.getElementById('modalOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal(e){ if(e.target===document.getElementById('modalOverlay')) closeModalDirect(); }
function closeModalDirect(){ document.getElementById('modalOverlay').classList.remove('open'); document.body.style.overflow=''; }
document.addEventListener('keydown',e=>{ if(e.key==='Escape') closeModalDirect(); });

/* ─── FETCH & BOOTSTRAP ─────────────────────────── */
async function loadContent() {
  try {
    // Cache-bust to avoid stale GitHub CDN
    const res = await fetch(JSON_URL + '?t=' + Date.now());
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const data = await res.json();
    allDataCache = data;
    allPostsCache = buildAllPosts(data);

    // Stats counters
    const stats = data.stats || {};
    new IntersectionObserver(entries=>{
      if(entries[0].isIntersecting){
        animCount(document.getElementById('countMembers'), stats.members||0);
        animCount(document.getElementById('countEps'),    stats.episodes||0);
        animCount(document.getElementById('countPosts'),  stats.posts||0);
      }
    },{threshold:0.5}).observe(document.querySelector('.hero-stats'));

    // Ticker from data
    if (data.ticker && data.ticker.length) {
      const inner = document.getElementById('tickerInner');
      const doubled = [...data.ticker, ...data.ticker];
      inner.innerHTML = doubled.map(t=>`<div class="ticker-item"><span class="ticker-dot"></span>${t}</div>`).join('');
    }

    renderFeatured(data);
    renderPosts('all');
    renderPodcasts(data.podcasts||[]);
    renderVideos(data.videos||[]);
    observeFadeIns();

  } catch(err) {
    console.error('JSON load error:', err);
    const errMsg = '<div class="error-state"><p>⚠️ تعذّر تحميل المحتوى. تحقق من ملف JSON.</p></div>';
    document.getElementById('featuredGrid').innerHTML = errMsg;
    document.getElementById('postsGrid').innerHTML   = errMsg;
    document.getElementById('podcastList').innerHTML = errMsg;
    document.getElementById('videosGrid').innerHTML  = errMsg;
  }
}

function handleSubmit(){
  const btn = document.querySelector('.form-submit');
  btn.textContent = '✓ تم الإرسال! سنراجع محتواك قريباً.';
  setTimeout(()=>{ btn.textContent='إرسال للمراجعة ←'; }, 3500);
}

loadContent();
</script>
</body>
</html>
